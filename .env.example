# Enable markdown -> prosody preprocessing in request text.
# 1=true, 0=false
TTS_MARKDOWN_PROSODY_ENABLED=1

# Pause inserted for a single newline (\n) when backend supports SSML break tags.
# Default chosen for natural flow within a sentence/line break.
TTS_MARKDOWN_LINE_BREAK_MS=350

# Pause inserted for paragraph breaks (blank line) when backend supports SSML break tags.
# Default chosen to create a stronger section boundary without sounding disconnected.
TTS_MARKDOWN_PARAGRAPH_BREAK_MS=900

# Optional comma-separated VibeVoice fallback model IDs (tried after MODEL_ID).
# Use this if the primary model checkpoint cannot be loaded for TTS.
# VIBEVOICE_MODEL_FALLBACKS=mlx-community/VibeVoice-bf16,mlx-community/VibeVoice-TTS-bf16
